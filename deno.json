{
  "name": "@denostack/openauth",
  "version": "0.4.2",
  "exports": {
    ".": "./core/mod.ts",
    "./github": "./github/mod.ts",
    "./google": "./google/mod.ts",
    "./facebook": "./facebook/mod.ts",
    "./kakao": "./kakao/mod.ts",
    "./naver": "./naver/mod.ts"
  },
  "tasks": {
    "bench": "deno run --allow-run=deno --allow-write=.benchmark scripts/benchmark.ts",
    "test": "deno task test:unit && deno task test:lint && deno task test:format && deno task test:types",
    "test:format": "deno fmt --check",
    "test:lint": "deno lint",
    "test:unit": "deno test -A",
    "test:types": "deno check core/mod.ts github/mod.ts google/mod.ts facebook/mod.ts kakao/mod.ts naver/mod.ts",
    "build:npm": "deno run --allow-env --allow-read --allow-write --allow-net --allow-run scripts/build_npm.ts"
  },
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.9",
    "@std/testing": "jsr:@std/testing@^1.0.17"
  },
  "lint": {
    "exclude": [".npm"]
  },
  "fmt": {
    "exclude": [".npm"],
    "lineWidth": 120
  },
  "publish": {
    "exclude": [".npm", ".github", ".vscode", "scripts", "examples", "**/*.test.ts"]
  }
}
